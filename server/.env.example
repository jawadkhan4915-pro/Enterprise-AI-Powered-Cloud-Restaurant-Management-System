# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/restaurant_os_ai

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_secret_key_123456
JWT_REFRESH_SECRET=your_super_secret_refresh_token_secret_key_123456
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Email SMTP Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=RestaurantOS AI <noreply@restaurantos.ai>

# Security
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100 # limit each IP to 100 requests per windowMs

# AI Provider Configurations (For Phase 8, but define now)
AI_PROVIDER=none # options: none, openai, ollama, lmstudio, openrouter
AI_MODEL=
AI_API_KEY=
AI_ENDPOINT=
